{
  "mode": "zone",
  "environment": "kubernetes",
  "experimental": {
    "autoReachableServices": false,
    "deltaXds": true,
    "sidecarContainers": true,
    "inboundTagsDisabled": true,
    "kdsEventBasedWatchdog": { "enabled": true }
  },
  "runtime": {
    "kubernetes": {
      "injector": {
        "unifiedResourceNamingEnabled": true,
        "ebpf": { "enabled": false }
      },
      "workloadLabels": ["app.kubernetes.io/name"]
    }
  }
}
